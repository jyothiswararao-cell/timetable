datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  name      String
  role      String     @default("FACULTY") // ADMIN, FACULTY
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  faculty   Faculty?
  auditLogs AuditLog[]
}

model Department {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  code      String    @unique
  faculties Faculty[]
  subjects  Subject[]
  classes   Class[]
}

model Faculty {
  id                  Int                  @id @default(autoincrement())
  name                String
  code                String               @unique
  email               String               @unique
  workloadLimit       Int                  @default(16) // Max periods/hours per week
  departmentId        Int
  department          Department           @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId              Int?                 @unique
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  subjects            Subject[]
  availabilities      FacultyAvailability[]
  timetables          Timetable[]
  workloadRequests    WorkloadRequest[]
  temporaryTimetables TemporaryTimetable[] @relation("ReplacementFaculty")
}

model Subject {
  id           Int         @id @default(autoincrement())
  name         String
  code         String      @unique
  credits      Int         @default(3)
  semester     Int
  departmentId Int
  department   Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  facultyId    Int?
  faculty      Faculty?    @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  timetables   Timetable[]
}

model Class {
  id           Int         @id @default(autoincrement())
  departmentId Int
  department   Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  semester     Int
  section      String
  strength     Int
  timetables   Timetable[]
}

model FacultyAvailability {
  id          Int     @id @default(autoincrement())
  facultyId   Int
  faculty     Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  dayOfWeek   String  // MONDAY, TUESDAY, WEDNESDAY, THURSDAY, FRIDAY, SATURDAY
  startTime   String  // e.g. "09:00"
  endTime     String  // e.g. "10:00"
  isAvailable Boolean @default(true)
}

model Timetable {
  id                  Int                  @id @default(autoincrement())
  classroom           String
  dayOfWeek           String               // MONDAY, TUESDAY, WEDNESDAY, THURSDAY, FRIDAY, SATURDAY
  startTime           String               // e.g. "09:00"
  endTime             String               // e.g. "10:00"
  classId             Int
  class               Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId           Int
  subject             Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  facultyId           Int
  faculty             Faculty              @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  temporaryTimetables TemporaryTimetable[]
}

model WorkloadRequest {
  id        Int      @id @default(autoincrement())
  facultyId Int
  faculty   Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  type      String   // INCREASE, DECREASE, TRANSFER
  amount    Int
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  suggestion String?
  createdAt DateTime @default(now())
}

model TemporaryTimetable {
  id                   Int       @id @default(autoincrement())
  date                 String    // YYYY-MM-DD
  timetableId          Int
  timetable            Timetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  replacementFacultyId Int
  replacementFaculty   Faculty   @relation("ReplacementFaculty", fields: [replacementFacultyId], references: [id], onDelete: Cascade)
  modifiedPeriod       String?   // e.g. "09:00-10:00"
  createdAt            DateTime  @default(now())
}

model ConflictReport {
  id          Int      @id @default(autoincrement())
  type        String   // FACULTY, ROOM, SUBJECT, DUPLICATE, UNAVAILABLE
  description String
  severity    String   // RED, ORANGE, YELLOW
  status      String   @default("UNRESOLVED") // UNRESOLVED, RESOLVED
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String
  timestamp DateTime @default(now())
}

model AcademicCalendar {
  id          Int     @id @default(autoincrement())
  date        String  @unique // YYYY-MM-DD
  type        String  // WORKING_DAY, HOLIDAY, EXAM_DAY, SPECIAL_EVENT
  description String?
}
